{
  "name": "openrouter-plus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "OpenRouter 模型列表浏览器 - 增强排序与筛选",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.build.json && node -e \"import('fs').then(({default:fs})=>fs.cpSync('public','dist/public',{recursive:true}))\"",
    "start:prod": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=18.0.0"
  }
}
